# 기본은 로컬 Ollama 실행입니다.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434/api/chat

# 성능 우선 PC라면 qwen3:30b, 추론 강화가 필요하면 deepseek-r1:8b도 테스트해볼 만합니다.
# LLM_MODEL=qwen3:30b
# LLM_MODEL=deepseek-r1:8b

# OpenAI API로 바꿀 때는 아래 줄의 주석을 해제하고 키를 넣으세요.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key

# EXAONE을 OpenAI-compatible server로 띄운 경우 예시입니다.
# LLM_PROVIDER=exaone
# LLM_MODEL=exaone
# EXAONE_BASE_URL=http://localhost:8000/v1
# EXAONE_API_KEY=exaone-local

ARXIV_MAX_RESULTS=3
ARXIV_MAX_ATTEMPTS=3
ARXIV_RETRY_WAIT_SECONDS=5
OUTPUT_DIR=outputs
